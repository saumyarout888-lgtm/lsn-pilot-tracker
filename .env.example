# Copy to .env.local for dev, or set these in Netlify → Site configuration →
# Environment variables. Vite inlines VITE_* vars at build time.

# Apps Script /exec URL (from `clasp deploy` or Deploy → New deployment)
VITE_SHEET_URL=https://script.google.com/macros/s/.../exec

# 4-digit PIN for the admin screen in the tracker PWA
VITE_ADMIN_PIN=0000
